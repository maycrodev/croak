###############################################################################
# Login comun
###############################################################################

# @name loginProf
POST {{gateway}}/auth/login
Content-Type: application/json

{ "email": "prof@croak.edu", "password": "prof123" }

###
@profToken = {{loginProf.response.body.access_token}}
@profId = {{loginProf.response.body.user.id}}

# @name loginStudent
POST {{gateway}}/auth/login
Content-Type: application/json

{ "email": "estudiante@croak.edu", "password": "estu123" }

###
@studentToken = {{loginStudent.response.body.access_token}}
@studentId = {{loginStudent.response.body.user.id}}

###############################################################################
# ESCENARIO A - Entrega dentro de plazo: flujo completo + sync con el LMS
###############################################################################

### A.1 Crear assignment con deadline FUTURO (2 casos, 50 + 50 puntos)
# @name createAssignment
POST {{gateway}}/assignments
Content-Type: application/json
Authorization: Bearer {{profToken}}

{
  "professor_id": {{profId}},
  "title": "Suma de dos enteros",
  "description": "Leer dos enteros de stdin y escribir su suma.",
  "language": "python",
  "deadline": "2026-12-31T23:59:00Z",
  "attempt_policy": "best",
  "criteria": [
    {
      "kind": "test_cases",
      "name": "Casos basicos",
      "test_cases": [
        { "stdin": "2 3\n",   "expected_stdout": "5",  "points": 50 },
        { "stdin": "10 20\n", "expected_stdout": "30", "points": 50 }
      ]
    }
  ]
}

###
@assignmentId = {{createAssignment.response.body.id}}

### A.2 Enviar codigo correcto
# @name submit
POST {{gateway}}/submissions
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "assignment_id": {{assignmentId}},
  "student_id": {{studentId}},
  "language": "python",
  "source_code": "a, b = map(int, input().split())\nprint(a + b)\n"
}

###
@submissionId = {{submit.response.body.id}}

### A.3 Ejecucion en sandbox (inciso I)
GET {{gateway}}/executions/{{submissionId}}
Authorization: Bearer {{studentToken}}

### A.4 Nota (inciso I) -> 100 / 100
GET {{gateway}}/grades/{{submissionId}}
Authorization: Bearer {{studentToken}}

### A.5 Sincronizacion con el LMS mainframe (inciso IV) -> synced, code 0000
GET {{gateway}}/lms/sync/{{submissionId}}
Authorization: Bearer {{profToken}}

### A.6 Reporte de plagio (inciso III)
GET {{gateway}}/plagiarism/{{submissionId}}
Authorization: Bearer {{studentToken}}

###############################################################################
# ESCENARIO B - Entrega fuera de plazo: rechazo por deadline (inciso V)
###############################################################################

### B.1 Crear assignment con deadline en el PASADO
# @name lateAssignment
POST {{gateway}}/assignments
Content-Type: application/json
Authorization: Bearer {{profToken}}

{
  "professor_id": {{profId}},
  "title": "Tarea con plazo vencido",
  "description": "Demuestra el rechazo por deadline.",
  "language": "python",
  "deadline": "2020-01-01T00:00:00Z",
  "attempt_policy": "best",
  "criteria": [
    { "kind": "test_cases", "name": "C",
      "test_cases": [ { "stdin": "1 1\n", "expected_stdout": "2", "points": 100 } ] }
  ]
}

###
@lateAssignmentId = {{lateAssignment.response.body.id}}

### B.2 Enviar a la tarea vencida -> HTTP 422
# @name lateSubmit
POST {{gateway}}/submissions
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "assignment_id": {{lateAssignmentId}},
  "student_id": {{studentId}},
  "language": "python",
  "source_code": "print(2)\n"
}

###
@rejectedId = {{lateSubmit.response.body.submission_id}}

### B.3 La submission quedo persistida con status=rejected
GET {{gateway}}/submissions/{{rejectedId}}
Authorization: Bearer {{profToken}}

###############################################################################
# ESCENARIO C - Intentos ilimitados, politica 'best' (inciso VI)
###############################################################################

### C.1 Crear assignment (attempt_policy = best)
# @name cAssignment
POST {{gateway}}/assignments
Content-Type: application/json
Authorization: Bearer {{profToken}}

{
  "professor_id": {{profId}},
  "title": "Suma - varios intentos",
  "description": "El estudiante puede reintentar; cuenta la mejor nota.",
  "language": "python",
  "deadline": "2026-12-31T23:59:00Z",
  "attempt_policy": "best",
  "criteria": [
    {
      "kind": "test_cases",
      "name": "Casos basicos",
      "test_cases": [
        { "stdin": "2 3\n",   "expected_stdout": "5",  "points": 50 },
        { "stdin": "10 20\n", "expected_stdout": "30", "points": 50 }
      ]
    }
  ]
}

###
@cAssignmentId = {{cAssignment.response.body.id}}

### C.2 Intento 1: codigo INCORRECTO -> nota baja
# @name cAttempt1
POST {{gateway}}/submissions
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "assignment_id": {{cAssignmentId}},
  "student_id": {{studentId}},
  "language": "python",
  "source_code": "print(0)\n"
}

###
@cSub1 = {{cAttempt1.response.body.id}}

### C.3 Nota del intento 1 -> espera 0 / 100
GET {{gateway}}/grades/{{cSub1}}
Authorization: Bearer {{studentToken}}

### C.4 Intento 2: codigo CORRECTO -> nota alta
# @name cAttempt2
POST {{gateway}}/submissions
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "assignment_id": {{cAssignmentId}},
  "student_id": {{studentId}},
  "language": "python",
  "source_code": "a, b = map(int, input().split())\nprint(a + b)\n"
}

###
@cSub2 = {{cAttempt2.response.body.id}}

### C.5 Nota del intento 2 -> espera 100 / 100
GET {{gateway}}/grades/{{cSub2}}
Authorization: Bearer {{studentToken}}

### C.6 Nota EFECTIVA (politica best) -> 100, source = intento 2
GET {{gateway}}/grades/effective?assignment_id={{cAssignmentId}}&student_id={{studentId}}
Authorization: Bearer {{profToken}}

###############################################################################
# ESCENARIO D - Criterio mixto: test_cases + metrics (inciso VII)
###############################################################################

### D.1 Crear assignment con test_cases (60) + metrics (30 + 30) = 120 -> cap 100
# @name dAssignment
POST {{gateway}}/assignments
Content-Type: application/json
Authorization: Bearer {{profToken}}

{
  "professor_id": {{profId}},
  "title": "Tarea con criterio mixto",
  "description": "Combina casos de prueba y metricas sobre la salida.",
  "language": "python",
  "deadline": "2026-12-31T23:59:00Z",
  "attempt_policy": "best",
  "criteria": [
    {
      "kind": "test_cases",
      "name": "Suma correcta",
      "test_cases": [
        { "stdin": "4 6\n", "expected_stdout": "RESULT\n10", "points": 60 }
      ]
    },
    {
      "kind": "metrics",
      "name": "Formato de salida",
      "rules": [
        { "type": "contains", "pattern": "RESULT", "points": 30 },
        { "type": "regex",    "pattern": "[0-9]+", "points": 30 }
      ]
    }
  ]
}

###
@dAssignmentId = {{dAssignment.response.body.id}}

### D.2 Enviar codigo que pasa el test_case y cumple las metricas
# @name dSubmit
POST {{gateway}}/submissions
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "assignment_id": {{dAssignmentId}},
  "student_id": {{studentId}},
  "language": "python",
  "source_code": "import sys\nnums = sys.stdin.read().split()\nprint(\"RESULT\")\nprint(sum(int(n) for n in nums))\n"
}

###
@dSubmissionId = {{dSubmit.response.body.id}}

### D.3 Nota con desglose -> breakdown: test_cases 60 + metrics 60, capped_at_100 true
GET {{gateway}}/grades/{{dSubmissionId}}
Authorization: Bearer {{studentToken}}

###############################################################################
# ESCENARIO E - Auditoria estatal: verificacion + export anual (contexto b)
###############################################################################

### E.1 Login como administrador (la entidad estatal opera con rol admin)
# @name loginAdmin
POST {{gateway}}/auth/login
Content-Type: application/json

{ "email": "admin@croak.edu", "password": "admin123" }

###
@adminToken = {{loginAdmin.response.body.access_token}}

### E.2 Bitacora completa: cada evento encadena su hash con el anterior
GET {{gateway}}/audit/events
Authorization: Bearer {{adminToken}}

### E.3 Verificar la integridad de TODA la cadena -> intact: true
GET {{gateway}}/audit/events/verify
Authorization: Bearer {{adminToken}}

### E.4 Export anual inmutable del anio 2026 (documento para la entidad estatal).
### export_seal = sha256( JSON canonico del documento SIN el campo export_seal ).
### JSON canonico = json.dumps(doc, sort_keys=True, separators=(",",":"), ensure_ascii=False).
### La entidad estatal recalcula ese sello para verificar que el archivo no fue alterado.
GET {{gateway}}/audit/export/annual?year=2026
Authorization: Bearer {{adminToken}}

### E.5 Export de un anio SIN eventos -> documento vacio valido (no error)
GET {{gateway}}/audit/export/annual?year=1999
Authorization: Bearer {{adminToken}}

### E.6 (negativo) un estudiante NO puede verificar la cadena -> HTTP 403
GET {{gateway}}/audit/events/verify
Authorization: Bearer {{studentToken}}

### E.7 (negativo) un profesor NO puede disparar el export estatal -> HTTP 403
GET {{gateway}}/audit/export/annual?year=2026
Authorization: Bearer {{profToken}}

###############################################################################
# F. Casos de error esperados
###############################################################################

### Sin token -> 401
GET {{gateway}}/grades/{{submissionId}}

### Submission inexistente -> 404
GET {{gateway}}/submissions/999999
Authorization: Bearer {{profToken}}

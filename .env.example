# CROAK - variables de entorno.
# Copia este archivo a `.env` (docker compose lo carga automaticamente).
# Los valores por defecto del docker-compose.yml ya permiten correr sin .env.

# --- PostgreSQL ---
POSTGRES_USER=croak
POSTGRES_PASSWORD=croak
POSTGRES_DB=croak

# --- Auth (JWT HS256) ---
# Cambiar en cualquier entorno que no sea local.
JWT_SECRET=croak-dev-secret-change-me

# --- Logging ---
LOG_LEVEL=INFO
